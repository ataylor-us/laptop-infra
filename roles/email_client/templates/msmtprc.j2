# {{ ansible_managed }}
account {{ personal_email }}
host {{ personal_email_imap_domain }}
port 465
from {{ personal_email }}
user {{ personal_email }}
passwordeval "{{ personal_mail_pass_command }}"
auth on
tls on
tls_trust_file /opt/homebrew/opt/ca-certificates/share/ca-certificates/cacert.pem
logfile ~/.local/state/msmtp/msmtp.log
tls_starttls off
